# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# AI服务配置
AI_API_KEY=your-api-key-here
AI_BASE_URL=https://api.openai.com/v1

# ASR 服务配置 (语音识别使用 OpenAI)
# 如果不设置,会复用 AI_API_KEY (但需要确保该 Key 支持 Whisper API)
ASR_API_KEY=your-api-key-here
ASR_BASE_URL=https://api.openai.com/v1

# 数据库配置
DB_HOST=localhost
DB_NAME=interview_db
DB_USER=postgres
DB_PASSWORD=postgres

# 应用配置
FLASK_ENV=development
FLASK_DEBUG=1
