# Required secrets
AI_API_KEY=your-ai-api-key-here
DB_PASSWORD=your-db-password-here

# The backend is served through FastAPI/uvicorn.
# Copy this file to backend/.env before running `uv run uvicorn main:app --reload`.

# Optional ASR override
# If omitted, the backend will fall back to AI_API_KEY where supported.
ASR_API_KEY=your-asr-api-key-here

# Xunfei digital human
XUNFEI_APP_ID=your-xunfei-app-id-here
XUNFEI_API_KEY=your-xunfei-api-key-here
XUNFEI_API_SECRET=your-xunfei-api-secret-here
XUNFEI_SCENE_ID=your-xunfei-scene-id-here
